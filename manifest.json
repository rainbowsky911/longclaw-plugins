{
  "manifest_version": 3,
  "name": "Longclaw URI Search",
  "version": "4.1.0",
  "description": "在绑定接口页面增加 URI 搜索功能",
  "permissions": ["storage"],
  "host_permissions": [
    "http://longclaw-admin-qa.ebanma.com/*","http://longclaw-admin-qa.csvw.ebanma.com/*","http://longclaw-admin-dev.fawww.ebanma.com/*","http://longclaw-admin.ebanma.com/*","http://longclaw-admin.csvw.ebanma.com/*","http://longclaw-admin.fawww.ebanma.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["http://longclaw-admin-qa.ebanma.com/*","http://longclaw-admin-qa.csvw.ebanma.com/*","http://longclaw-admin-dev.fawww.ebanma.com/*","http://longclaw-admin.ebanma.com/*","http://longclaw-admin.csvw.ebanma.com/*","http://longclaw-admin.fawww.ebanma.com/*"],
      "js": ["inject.js"],
      "css": ["content.css"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["page.js"],
      "matches": ["http://longclaw-admin-qa.ebanma.com/*","http://longclaw-admin-qa.csvw.ebanma.com/*","http://longclaw-admin-dev.fawww.ebanma.com/*","http://longclaw-admin.ebanma.com/*","http://longclaw-admin.csvw.ebanma.com/*","http://longclaw-admin.fawww.ebanma.com/*"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
